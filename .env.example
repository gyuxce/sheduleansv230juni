NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Legacy Supabase projects may use NEXT_PUBLIC_SUPABASE_ANON_KEY instead.
# Server-only. Never prefix this variable with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Integration tests - use local or isolated staging, never production.
TEST_SUPABASE_URL=http://127.0.0.1:54321
TEST_SUPABASE_PUBLISHABLE_KEY=your-local-anon-key
TEST_SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key
# Required only when intentionally targeting an isolated remote staging project.
ALLOW_REMOTE_INTEGRATION_TESTS=false
